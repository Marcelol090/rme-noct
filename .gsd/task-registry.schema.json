{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./.gsd/task-registry.schema.json",
  "title": "PyRME Task Registry",
  "description": "Writable durable memory for completed, in-progress, and planned work items.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "project", "updated_at", "tasks"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task_record"
      }
    }
  },
  "$defs": {
    "task_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "status",
        "milestone",
        "slice",
        "summary",
        "done_criteria",
        "scope",
        "tests_run",
        "recorded_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": ["feature", "infrastructure", "docs", "test", "workflow"]
        },
        "status": {
          "type": "string",
          "enum": ["planned", "in_progress", "implemented", "verified", "blocked", "deferred"]
        },
        "milestone": {
          "type": "string",
          "minLength": 1
        },
        "slice": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "done_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "files_modified": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tests_run": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "notes"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_run", "partial", "passed"]
            },
            "notes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}

{
  "name": "pyrme-devtools",
  "version": "0.1.0",
  "private": true,
  "description": "DevTools dependencies for PyRME (GSD-2 integration)",
  "scripts": {
    "setup": "bash scripts/setup-devtools.sh",
    "gsd": "node scripts/run-gsd.mjs",
    "gsd:patch": "node scripts/patch-gsd-pi.mjs",
    "gsd:auto": "node scripts/run-gsd.mjs headless auto",
    "gsd:plan": "node scripts/run-gsd.mjs headless new-milestone --context-text",
    "gsd:status": "node scripts/run-gsd.mjs headless query",
    "stack": "node scripts/run-python.mjs -m pyrme stack",
    "preflight": "npm run stack",
    "stack:json": "node scripts/run-python.mjs -m pyrme stack --json",
    "dev:check": "npm run preflight && node scripts/run-python.mjs -m ruff check pyrme && node scripts/run-python.mjs -m mypy pyrme",
    "postinstall": "node scripts/patch-gsd-pi.mjs"
  },
  "devDependencies": {
    "gsd-pi": "2.64.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
